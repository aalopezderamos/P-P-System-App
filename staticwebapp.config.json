{
  "routes": [
    {
      "route": "/",
      "rewrite": "/static/index.html"
    },
    {
      "route": "/predict",
      "rewrite": "/static/predict.html"
    },
    {
      "route": "/pour",
      "rewrite": "/static/pour.html"
    },
    {
      "route": "/admin",
      "rewrite": "/static/admin.html"
    },
    {
      "route": "*.py",
      "statusCode": 404
    },
    {
      "route": "/Dockerfile",
      "statusCode": 404
    },
    {
      "route": "/requirements.txt",
      "statusCode": 404
    },
    {
      "route": "/init_db.py",
      "statusCode": 404
    },
    {
      "route": "/.dockerignore",
      "statusCode": 404
    }
  ],
  "navigationFallback": {
    "rewrite": "/static/index.html",
    "exclude": ["/static/*", "/api/*"]
  }
}
