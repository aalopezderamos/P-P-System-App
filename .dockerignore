# Virtual environment — never goes in the container
venv/
.venv/

# Python cache
__pycache__/
*.pyc
*.pyo
*.pyd

# ML training artifacts / logs — regenerated at runtime
lightning_logs/
catboost_info/
index_files/

# Local database — should not ship in the image
users.db
*.db

# User management scripts — not needed in the running container
add_users.py
create_first_user.py

# Git
.git/
.gitignore

# OS / editor junk
.DS_Store
*.swp

# Docker
Dockerfile
.dockerignore
